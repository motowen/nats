GET /user_roles	rbac.system.get_members
POST /user_roles/resources/owner	rbac.resource.assign_owner
...	...
每個 handler 需要：

從 NATS message 的 payload 反序列化 request（JSON）
從 NATS connection context 或 message header 取得 callerID
呼叫現有的 service 層方法（邏輯不用改）
序列化 response 回傳
3. 🔐 RBAC 角色 → NATS Permissions 映射層（新增）
這是 Auth Callout 最關鍵的部分 — 你需要新增一個映射邏輯：

go
// 例如：根據 RBAC 角色產生 NATS subject permissions
func MapRolesToNATSPermissions(roles []*model.UserRole) NATSPermissions {
    perms := NATSPermissions{}
    for _, role := range roles {
        switch {
        case role.Scope == "system" && role.Role == "owner":
            // 可以 publish/subscribe namespace 底下所有 subjects
            perms.Publish.Allow = append(perms.Publish.Allow, 
                fmt.Sprintf("rbac.%s.>", role.Namespace))
            perms.Subscribe.Allow = append(perms.Subscribe.Allow,
                fmt.Sprintf("rbac.%s.>", role.Namespace))
        case role.Scope == "system" && role.Role == "viewer":
            // 只能 subscribe / 發 read 請求
            perms.Subscribe.Allow = append(perms.Subscribe.Allow,
                fmt.Sprintf("rbac.%s.read.>", role.Namespace))
        // ... 其他角色映射
        }
    }
    return perms
}
